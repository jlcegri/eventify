<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="1030.0" spacing="15.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.Controllers.LoginController">
    <children>
        <StackPane>
            <children>
                <Circle radius="25.0" styleClass="logo-circle" />
                <Text style="-fx-font-size: 20px;" styleClass="logo-text" text="E" />
            </children>
        </StackPane>

        <Label style="-fx-font-size: 24px; -fx-font-weight: 900;" text="Welcome Back!" />
        <Label style="-fx-text-fill: #888; -fx-text-alignment: CENTER;" text="Sign in to discover amazing events and connect with your&#10;community" textAlignment="CENTER" wrapText="true" />

        <VBox maxWidth="400.0" spacing="15.0">
            <children>

                <VBox spacing="5.0">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Email Address" />
                    <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                        <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="#999" scaleX="0.7" scaleY="0.7" />
                        <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <VBox spacing="5.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Password" HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6C63FF; -fx-cursor: hand;" text="Forgot password?" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                        <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" fill="#999" scaleX="0.7" scaleY="0.7" />
                        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                        <SVGPath content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" fill="#999" scaleX="0.7" scaleY="0.7" style="-fx-cursor: hand;" />
                    </HBox>
                </VBox>

                <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button" text="Sign In">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin></Button>

                <HBox alignment="CENTER">
                    <Label style="-fx-text-fill: #888;" text="Don't have an account? " />
                    <Label onMouseClicked="#handleJoinLink" styleClass="link-text" text="Join Eventify" />
                </HBox>
            </children>
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
        </VBox>
    </children>
    <padding>
        <Insets bottom="50.0" top="50.0" />
    </padding>
</VBox>
