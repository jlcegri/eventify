<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="1030.0" spacing="15.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.Controllers.RegisterController">
    <children>
        <StackPane>
            <children>
                <Circle radius="20.0" styleClass="logo-circle" />
                <Text style="-fx-font-size: 18px;" styleClass="logo-text" text="E" />
            </children>
        </StackPane>

        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Create Your Account" />
        <Label style="-fx-text-fill: #888;" text="Start your journey to meaningful connections" />

        <VBox maxWidth="400.0" spacing="15.0">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="First Name" />
                            <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="#999" scaleX="0.7" scaleY="0.7" />
                                <TextField fx:id="firstNameField" promptText="John" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Last Name" />
                            <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                                <TextField fx:id="lastNameField" promptText="Doe" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Email Address" />
                    <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                        <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="#999" scaleX="0.7" scaleY="0.7" />
                        <TextField fx:id="emailField" promptText="john@example.com" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <VBox spacing="5.0">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Password" />
                    <HBox alignment="CENTER_LEFT" styleClass="input-field-container">
                        <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" fill="#999" scaleX="0.7" scaleY="0.7" />
                        <PasswordField fx:id="passwordField" promptText="Create a strong password" styleClass="text-field-transparent" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <CheckBox fx:id="termsCheckBox" style="-fx-font-size: 12px; -fx-text-fill: #666;" text="I agree to the Terms of Service and Privacy Policy" />

                <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="primary-button" text="Create Account" />

                <HBox alignment="CENTER">
                    <Label style="-fx-text-fill: #888;" text="Already have an account? " />
                    <Label onMouseClicked="#handleSignInLink" styleClass="link-text" text="Sign In" />
                </HBox>
            </children>
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
        </VBox>
    </children>
    <padding>
        <Insets bottom="50.0" top="50.0" />
    </padding>
</VBox>
