<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="1030.0" spacing="20.0" styleClass="root" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.Controllers.LandingPageController">
    <children>
        <StackPane>
            <children>
                <Circle radius="30.0" styleClass="logo-circle" />
                <Text styleClass="logo-text" text="E" />
            </children>
        </StackPane>

        <Label styleClass="title-label" text="Eventify" />
        <Label styleClass="subtitle-label" text="Discover amazing local events, connect with like-minded&#10;people, and make real-world connections easier, safer, and&#10;more fun." textAlignment="CENTER" wrapText="true" />

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="getStartedButton" mnemonicParsing="false" onAction="#handleGetStarted" styleClass="primary-button" text="Get Started" />
                <Button fx:id="signInButton" mnemonicParsing="false" onAction="#handleSignIn" styleClass="secondary-button" text="Sign In" />
            </children>
            <padding>
                <Insets bottom="30.0" top="10.0" />
            </padding>
        </HBox>

        <HBox alignment="CENTER" spacing="50.0">
            <children>
                <VBox alignment="TOP_CENTER" maxWidth="250.0" spacing="10.0" styleClass="my-double-border">
                    <Label style="-fx-font-size: 24px;" text="🎯" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Personalized Discovery" />
                    <Label style="-fx-text-fill: #888; -fx-font-size: 12px;" text="AI-powered recommendations based on your interests and location" textAlignment="CENTER" wrapText="true" />
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
                </VBox>
                <VBox alignment="TOP_CENTER" maxWidth="250.0" spacing="10.0" styleClass="my-double-border">
                    <Label style="-fx-font-size: 24px;" text="🎉" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Easy Management" />
                    <Label style="-fx-text-fill: #888; -fx-font-size: 12px;" text="Simple event creation and management tools for organizers" textAlignment="CENTER" wrapText="true" />
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
                </VBox>
            </children>
        </HBox>

    </children>
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>
</VBox>
