                           <children>
                              <SVGPath content="m12 19-7-7 7-7 M19 12H5" fill="TRANSPARENT" scaleX="0.7" scaleY="0.7" stroke="BLACK" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" styleClass="iteractive-buttons-create" />
