                              <Pane prefHeight="91.0" prefWidth="200.0" styleClass="my-double-border">
                                 <children>
                                    <Button fx:id="joinEventButton" alignment="CENTER" layoutX="44.0" layoutY="33.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="140.0" styleClass="continue-button" text="Join Event" textFill="WHITE">
                                       <font>
