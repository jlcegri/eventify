                                       </font>
                                    </Button>
                                 </children>
                              </Pane>
                              <VBox prefHeight="210.0" styleClass="my-double-border">
                                 <children>
                                    <Label prefHeight="17.0" prefWidth="548.0" style="-fx-font-size: 13px; -fx-font-weight: 700;" text="Who's going">
