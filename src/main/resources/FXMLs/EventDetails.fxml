                                       </VBox.margin>
                                    </Label>
                                    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" hmax="0.0" prefHeight="334.0" prefWidth="218.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="NEVER">
                                       <content>
                                          <VBox fx:id="Attendees" alignment="TOP_CENTER" />
                                       </content>
                                    </ScrollPane>
                                    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
